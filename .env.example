# Kuditax — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── WhatsApp / Meta Cloud API ───────────────────────────────────────────────
# From the Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Token you choose during webhook setup in the Meta Developer Console
WHATSAPP_VERIFY_TOKEN=

# App Secret from Meta Developer Console → Your App → Settings → Basic
# Used to verify the X-Hub-Signature-256 header on incoming webhook POST requests
WHATSAPP_APP_SECRET=

# ── Anthropic ──────────────────────────────────────────────────────────────
# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
