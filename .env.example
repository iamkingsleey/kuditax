# Kuditax — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── WhatsApp / Meta Cloud API ───────────────────────────────────────────────
# From the Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Token you choose during webhook setup in the Meta Developer Console
WHATSAPP_VERIFY_TOKEN=

# App Secret from Meta Developer Console → Your App → Settings → Basic
# Used to verify the X-Hub-Signature-256 header on incoming webhook POST requests
WHATSAPP_APP_SECRET=

# ── Anthropic ──────────────────────────────────────────────────────────────
# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Firebase Firestore ──────────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Place the JSON file in the project root and set the path below.
# If unset, the bot runs in memory-only mode (no profile persistence).
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
